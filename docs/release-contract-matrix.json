{
  "schema_version": 1,
  "title": "RCH Python Parity Plus Rust Release Capability Contract Matrix",
  "baseline": {
    "python_branch": "rch-python",
    "rust_branch": "rust-next",
    "compatibility_rule": "Match Python where Python exposes an external contract; require Rust additive capabilities where the Rust edition intentionally goes beyond Python."
  },
  "classifications": {
    "must-match-python": "Externally observable Python RCH 2.9.x behavior that Rust must preserve.",
    "rust-additive-required": "Rust release capability with no required Python equivalent.",
    "intentional-difference": "Architecture difference that is acceptable when public behavior is equivalent or improved."
  },
